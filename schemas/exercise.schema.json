{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spoludo.github.io/valens/schemas/exercise.schema.json",
  "title": "Valens Exercise Definition",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_-]*$"
    },
    "schemaVersion": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "localizedKey": {
      "type": "string",
      "pattern": "^[a-zA-Z0-9_.-]+$"
    },
    "zeroToOne": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "zeroToTenInteger": {
      "type": "integer",
      "minimum": 0,
      "maximum": 10
    },
    "equipmentItem": {
      "type": "string",
      "enum": [
        "none",
        "wall",
        "floor",
        "chair",
        "mat",
        "bar",
        "band",
        "dumbbell",
        "backpack",
        "timer"
      ]
    },
    "exerciseType": {
      "type": "string",
      "enum": [
        "isometric",
        "dynamic",
        "mobility_dynamic",
        "mobility_isometric",
        "balance",
        "assessment",
        "breathing"
      ]
    },
    "sideModel": {
      "type": "string",
      "enum": [
        "bilateral",
        "left_right",
        "single_side",
        "midline"
      ]
    },
    "jointLoadRole": {
      "type": "string",
      "enum": [
        "bilateral",
        "midline",
        "workingSide",
        "supportSide",
        "oppositeSide",
        "left",
        "right"
      ]
    },
    "jointStressByRole": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "$ref": "#/$defs/zeroToOne"
      },
      "propertyNames": {
        "$ref": "#/$defs/jointLoadRole"
      }
    },
    "jointFatigueByRole": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "$ref": "#/$defs/zeroToTenInteger"
      },
      "propertyNames": {
        "$ref": "#/$defs/jointLoadRole"
      }
    },
    "muscleLoad": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "load"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "load": {
          "$ref": "#/$defs/zeroToOne"
        }
      }
    }
  },
  "required": [
    "id",
    "schemaVersion",
    "nameKey",
    "descriptionKey",
    "type",
    "movementPatternId",
    "exerciseFamilyId",
    "difficulty",
    "equipment",
    "homeFriendly",
    "sideModel",
    "defaultPrescription",
    "muscles",
    "jointStress",
    "fatigueCost",
    "progression",
    "regressions",
    "alternatives",
    "contraindications",
    "cues",
    "assets"
  ],
  "properties": {
    "id": {
      "$ref": "#/$defs/id"
    },
    "schemaVersion": {
      "$ref": "#/$defs/schemaVersion"
    },
    "nameKey": {
      "$ref": "#/$defs/localizedKey"
    },
    "descriptionKey": {
      "$ref": "#/$defs/localizedKey"
    },
    "type": {
      "$ref": "#/$defs/exerciseType"
    },
    "movementPatternId": {
      "$ref": "#/$defs/id"
    },
    "exerciseFamilyId": {
      "$ref": "#/$defs/id"
    },
    "difficulty": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5
    },
    "equipment": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/equipmentItem"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "homeFriendly": {
      "type": "boolean"
    },
    "sideModel": {
      "$ref": "#/$defs/sideModel"
    },
    "defaultPrescription": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sets",
        "restSeconds"
      ],
      "properties": {
        "sets": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10
        },
        "holdSeconds": {
          "type": "integer",
          "minimum": 1,
          "maximum": 600
        },
        "durationSeconds": {
          "type": "integer",
          "minimum": 1,
          "maximum": 600
        },
        "restSeconds": {
          "type": "integer",
          "minimum": 0,
          "maximum": 300
        },
        "targetReps": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100
        },
        "intensityTarget": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10
        },
        "tempo": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "eccentricSeconds": {
              "type": "number",
              "minimum": 0
            },
            "bottomPauseSeconds": {
              "type": "number",
              "minimum": 0
            },
            "concentricCue": {
              "type": "string"
            },
            "topPauseSeconds": {
              "type": "number",
              "minimum": 0
            }
          }
        }
      }
    },
    "muscles": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "primary",
        "secondary",
        "stabilizers"
      ],
      "properties": {
        "primary": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/muscleLoad"
          }
        },
        "secondary": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/muscleLoad"
          }
        },
        "stabilizers": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/muscleLoad"
          }
        }
      }
    },
    "jointStress": {
      "type": "object",
      "description": "Map anatomical joint id to relative stress by side role.",
      "additionalProperties": {
        "$ref": "#/$defs/jointStressByRole"
      }
    },
    "fatigueCost": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "global",
        "local",
        "joint"
      ],
      "properties": {
        "global": {
          "$ref": "#/$defs/zeroToTenInteger"
        },
        "local": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/zeroToTenInteger"
          }
        },
        "joint": {
          "type": "object",
          "description": "Map anatomical joint id to fatigue cost by side role.",
          "additionalProperties": {
            "$ref": "#/$defs/jointFatigueByRole"
          }
        }
      }
    },
    "progression": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "labelKey",
          "difficulty"
        ],
        "additionalProperties": true,
        "properties": {
          "id": {
            "$ref": "#/$defs/id"
          },
          "labelKey": {
            "$ref": "#/$defs/localizedKey"
          },
          "difficulty": {
            "type": "integer",
            "minimum": 1,
            "maximum": 10
          },
          "holdSeconds": {
            "type": "integer",
            "minimum": 1
          },
          "sets": {
            "type": "integer",
            "minimum": 1
          },
          "restSeconds": {
            "type": "integer",
            "minimum": 0
          },
          "kneeAngleDegrees": {
            "type": "integer",
            "minimum": 30,
            "maximum": 180
          },
          "variationKey": {
            "$ref": "#/$defs/localizedKey"
          }
        }
      },
      "minItems": 1
    },
    "regressions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/id"
      },
      "uniqueItems": true
    },
    "alternatives": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/id"
      },
      "uniqueItems": true
    },
    "contraindications": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "acute_knee_pain",
          "acute_shoulder_pain",
          "acute_wrist_pain",
          "acute_low_back_pain",
          "dizziness",
          "uncontrolled_hypertension",
          "requires_overhead_tolerance",
          "requires_floor_access",
          "requires_bar"
        ]
      },
      "uniqueItems": true
    },
    "cues": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "setup",
        "during",
        "stopIf"
      ],
      "properties": {
        "setup": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/localizedKey"
          }
        },
        "during": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/localizedKey"
          }
        },
        "stopIf": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/localizedKey"
          }
        }
      }
    },
    "assets": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "illustration": {
          "type": "string"
        },
        "illustrationStart": {
          "type": "string"
        },
        "illustrationHold": {
          "type": "string"
        },
        "illustrationMistake": {
          "type": "string"
        },
        "muscleMapFront": {
          "type": "string"
        },
        "muscleMapBack": {
          "type": "string"
        },
        "jointMapFront": {
          "type": "string"
        },
        "jointMapBack": {
          "type": "string"
        }
      }
    }
  }
}
