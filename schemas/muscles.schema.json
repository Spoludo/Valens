{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Valens Muscle Collection",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "muscles"
  ],
  "properties": {
    "schemaVersion": {
      "$ref": "#/$defs/schemaVersion"
    },
    "muscles": {
      "type": "array",
      "items": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "title": "Valens Muscle",
        "type": "object",
        "additionalProperties": false,
        "$defs": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9_-]*$"
          },
          "schemaVersion": {
            "type": "string",
            "pattern": "^\\d+\\.\\d+\\.\\d+$"
          },
          "localizedKey": {
            "type": "string",
            "pattern": "^[a-zA-Z0-9_.-]+$"
          },
          "zeroToOne": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          }
        },
        "required": [
          "id",
          "nameKey",
          "region"
        ],
        "properties": {
          "id": {
            "$ref": "#/$defs/id"
          },
          "nameKey": {
            "$ref": "#/$defs/localizedKey"
          },
          "region": {
            "enum": [
              "neck",
              "shoulder",
              "chest",
              "back",
              "core",
              "hip",
              "thigh",
              "lower_leg",
              "arm",
              "forearm",
              "full_body"
            ]
          },
          "side": {
            "enum": [
              "left",
              "right",
              "bilateral",
              "midline"
            ]
          }
        }
      }
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_-]*$"
    },
    "schemaVersion": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "localizedKey": {
      "type": "string",
      "pattern": "^[a-zA-Z0-9_.-]+$"
    },
    "zeroToOne": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    }
  }
}
